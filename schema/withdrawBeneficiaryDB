const mongoose = require("mongoose");

const withdrawBeneficiarySchema = new mongoose.Schema(
  {
    userId: {
      type: mongoose.Schema.Types.ObjectId,
      required: true,
    },

    accountId: {
      type: String,
      required: true,
    },

    network: {
      type: String,
      required: true,
    },

    asset: {
      type: String,
      required: true,
    },

    address: {
      type: String,
      required: true,
    },

    sourceWalletId: {
      type: String,
      required: true,
    },
  },
  {
    timestamps: true,
  },
);

module.exports = mongoose.model(
  "withdrawBeneficiary",
  withdrawBeneficiarySchema,
);